{
  "name": "zx-vibes-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "ZX Spectrum vibe-coding monorepo: emulator, assembler, toolkit, starters, MCP, and create package.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check:gallery-bundles": "node scripts/check-gallery-bundles.js",
    "check:starter-templates": "node scripts/check-starter-template-drift.js",
    "docs:dev": "vitepress dev docs/manual",
    "docs:build": "vitepress build docs/manual",
    "docs:preview": "vitepress preview docs/manual",
    "check:drift": "pnpm --filter create-zx-vibes run check:assets && pnpm --filter @zx-vibes/toolkit run check:docs && pnpm run check:starter-templates && pnpm run check:gallery-bundles",
    "build": "pnpm -r --sort run build",
    "typecheck": "pnpm -r --sort run typecheck",
    "test": "pnpm -r --sort run test",
    "lint": "pnpm -r --sort run lint",
    "pack": "pnpm -r --filter \"./packages/*\" --workspace-concurrency=1 pack --pack-destination .packs",
    "verify": "pnpm run check:drift && pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "form-data": "4.0.6",
      "js-yaml": "4.2.0",
      "read-yaml-file": "2.1.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
