node_modules/
dist/
build/
coverage/
.cache/
.zxs/
.packs/
*.log
*.tgz
tmp/
temp/
.feedback/

# Local agent instructions and operational harness. decisions.md is tracked:
# it is the ADR/provenance log that dna/conformance/provenance-lint.mjs
# validates decision references against.
/AGENTS.md
/.harness/*
!/.harness/decisions.md
/.claude/

# Local game images for manual testing (not redistributable)
/tapes/

# The `build/` rule above (generated assembler output) would also swallow the
# toolkit's build-service SOURCE directory; re-include it explicitly.
!/packages/toolkit/src/build/
!/packages/toolkit/src/build/**
