  "input": {
    "kind": "cpu-step",
    "note": "RETI (ED 4D) restores the maskable-interrupt flip-flop IFF1 from IFF2, exactly like RETN. This is verified Z80 silicon behavior (FUSE and zexall agree; 'The Undocumented Z80 Documented' §5.4); the official Zilog manual documents the IFF1 restore only for RETN. The pinned FUSE ED4D case enters with IFF2=0, so it cannot distinguish a RETI that restores IFF1 from one that leaves it unchanged. These two cases close that net hole by entering with IFF1 != IFF2 in BOTH directions: a RETI that does not copy IFF2 into IFF1 fails at least one. Backs dna/domain/z80-opcodes.md Z80-OPC-RETN-RETI-001.",
    "cases": [
      {
        "name": "reti_iff_restore_set",
        "registers": { "sp": "6000", "iff1": "00", "iff2": "01" },
        "memory": { "0000": "ED4D", "6000": "4242" }
      },
      {
        "name": "reti_iff_restore_clear",
        "registers": { "sp": "6000", "iff1": "01", "iff2": "00" },
        "memory": { "0000": "ED4D", "6000": "4242" }
      }
    ]
  },
