{
  "name": "zx-vibes",
  "version": "0.3.0",
  "description": "User-facing ZX Spectrum vibe-coding package with zxs, zxs-mcp, and zxasm bins.",
  "license": "MIT",
  "author": "Alvaro Mateos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alvaromah/zx-vibes.git",
    "directory": "packages/zx-vibes"
  },
  "homepage": "https://github.com/Alvaromah/zx-vibes#readme",
  "bugs": {
    "url": "https://github.com/Alvaromah/zx-vibes/issues"
  },
  "keywords": [
    "zx-spectrum",
    "z80",
    "assembler",
    "emulator",
    "cli",
    "mcp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "zx-vibes": "bin/zx-vibes.js",
    "zxs": "bin/zxs.js",
    "zxs-mcp": "bin/zxs-mcp.js",
    "zxasm": "bin/zxasm.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "test": "node scripts/smoke-test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src bin"
  },
  "dependencies": {
    "@zx-vibes/asm": "workspace:*",
    "@zx-vibes/toolkit": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
