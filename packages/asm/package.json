{
  "name": "@zx-vibes/asm",
  "version": "0.1.0",
  "description": "zx-vibes Z80 assembler/disassembler for ZX Spectrum 48K workflows.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "spectral-asm": "dist/cli.js",
    "zxasm": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && node ../../scripts/ensure-shebang.js dist/cli.js",
    "prepack": "pnpm run build",
    "test": "tsup --silent && node ../../scripts/ensure-shebang.js --silent dist/cli.js && vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "prettier": "^3.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  }
}
